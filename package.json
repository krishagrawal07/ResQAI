{
  "name": "resqai",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "backend": "npm --prefix backend run dev",
    "dashboard": "npm --prefix dashboard run dev",
    "demo:check": "powershell -ExecutionPolicy Bypass -File scripts/demo-check.ps1",
    "demo:start": "powershell -ExecutionPolicy Bypass -File scripts/demo-start.ps1",
    "demo:stop": "powershell -ExecutionPolicy Bypass -File scripts/demo-stop.ps1",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "postinstall": "node scripts/patch-react-native-background-actions.js",
    "setup:all": "npm install && npm --prefix backend install && npm --prefix dashboard install",
    "start": "react-native start",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.21.0",
